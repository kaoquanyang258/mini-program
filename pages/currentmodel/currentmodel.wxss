.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(255, 193, 107, 0.28), transparent 32%),
    linear-gradient(180deg, #fff7e8 0%, #f6f7fb 54%, #eef4f8 100%);
}

.hero-card,
.current-card,
.model-card,
.tips-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(54, 63, 96, 0.08);
}

.hero-card {
  padding: 34rpx 30rpx;
  background: linear-gradient(145deg, rgba(44, 89, 58, 0.95), rgba(20, 40, 67, 0.92));
  color: #fff;
}

.eyebrow {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  opacity: 0.72;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 54rpx;
  line-height: 1.15;
  font-weight: 700;
}

.hero-desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.82);
}

.current-card {
  margin-top: 24rpx;
  padding: 28rpx 30rpx;
  border: 2rpx solid rgba(44, 89, 58, 0.08);
}

.current-label {
  font-size: 24rpx;
  color: #6f7b8c;
}

.current-name {
  margin-top: 10rpx;
  font-size: 44rpx;
  color: #22314b;
  font-weight: 700;
}

.current-folder,
.current-status,
.model-folder,
.model-desc,
.model-path,
.tips-text {
  font-size: 26rpx;
  line-height: 1.7;
}

.current-folder {
  margin-top: 10rpx;
  color: #536179;
  word-break: break-all;
}

.current-status {
  margin-top: 16rpx;
  color: #2f7d57;
}

.section-title {
  margin: 34rpx 6rpx 20rpx;
  font-size: 32rpx;
  color: #22314b;
  font-weight: 700;
}

.model-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.model-card {
  padding: 28rpx;
  border: 2rpx solid transparent;
}

.model-card-active {
  border-color: rgba(44, 89, 58, 0.28);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(239, 248, 242, 0.95));
}

.model-card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.model-name {
  font-size: 38rpx;
  color: #1f2d45;
  font-weight: 700;
}

.model-folder {
  margin-top: 8rpx;
  color: #6d7889;
}

.model-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef1f5;
  color: #5d6a7c;
  font-size: 22rpx;
}

.model-badge-active {
  background: #2f7d57;
  color: #fff;
}

.model-desc {
  margin-top: 20rpx;
  color: #344158;
}

.model-path {
  margin-top: 14rpx;
  color: #7b8798;
  word-break: break-all;
}

.switch-button {
  margin-top: 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  border: none;
  background: #1f3557;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.switch-button-active {
  background: #dfe8e1;
  color: #486253;
}

.switch-button[disabled] {
  opacity: 0.78;
}

.tips-card {
  margin-top: 28rpx;
  padding: 28rpx 30rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #22314b;
  margin-bottom: 12rpx;
}

.tips-text {
  color: #5f6b7d;
}

.back-button {
  margin-top: 32rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 18rpx;
  border: none;
  background: linear-gradient(135deg, #d9534f, #b9322e);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}
