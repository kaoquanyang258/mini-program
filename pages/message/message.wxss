page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(255, 195, 123, 0.25), transparent 30%),
    linear-gradient(180deg, #f7f4ee 0%, #eef3f9 100%);
}

.page {
  padding: 28rpx;
  box-sizing: border-box;
}

.user-card,
.button-list,
.modal-content {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(52, 65, 88, 0.08);
}

.user-card {
  padding: 34rpx 32rpx;
  margin-bottom: 24rpx;
}

.user-title {
  font-size: 24rpx;
  color: #6d7889;
}

.user-name {
  margin-top: 12rpx;
  font-size: 46rpx;
  font-weight: 700;
  color: #22314b;
}

.user-account {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #526078;
}

.user-tag {
  display: inline-block;
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(87, 107, 149, 0.12);
  color: #43506a;
  font-size: 24rpx;
}

.button-list {
  overflow: hidden;
}

.button-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 32rpx;
  font-size: 32rpx;
  color: #333;
  border-bottom: 1rpx solid #eee;
}

.button-item:last-child {
  border-bottom: none;
}

.button-item:active {
  background: rgba(87, 107, 149, 0.06);
}

.button-item-danger {
  color: #d64545;
}

.arrow {
  color: #999;
  font-size: 40rpx;
  line-height: 1;
}

.feedback-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.48);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 84%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-title {
  padding: 30rpx;
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  border-bottom: 1rpx solid #eee;
  color: #22314b;
}

.modal-body {
  padding: 30rpx;
}

.feedback-input,
.feedback-textarea {
  width: 100%;
  border-radius: 16rpx;
  background: #f7f9fc;
  font-size: 28rpx;
  box-sizing: border-box;
}

.feedback-input {
  height: 88rpx;
  padding: 0 20rpx;
  margin-bottom: 22rpx;
}

.feedback-textarea {
  min-height: 220rpx;
  padding: 20rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #eee;
}

.modal-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  font-size: 32rpx;
  border-radius: 0;
  background: white;
  margin: 0;
}

.modal-btn.cancel {
  color: #666;
  border-right: 1rpx solid #eee;
}

.modal-btn.submit {
  color: #07c160;
  font-weight: 600;
}

.back-button-container {
  margin-top: 40rpx;
}

.back-button {
  background: linear-gradient(135deg, #d9534f, #b9322e);
  color: white;
  border-radius: 18rpx;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 30rpx;
  border: none;
}
